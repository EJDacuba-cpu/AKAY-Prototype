APP_NAME="AKAY API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Manila
FRONTEND_URL=http://localhost:5173
AKAY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AKAY_TRUSTED_HOSTS=localhost
AKAY_TRUSTED_PROXIES=
AKAY_SECURITY_HEADERS_ENABLED=true
AKAY_CSP_MODE=report-only
AKAY_CSP_CONNECT_ORIGINS=
AKAY_HTTPS_REDIRECT_ENABLED=false
AKAY_HSTS_ENABLED=false
AKAY_HSTS_MAX_AGE=31536000
AKAY_HSTS_INCLUDE_SUBDOMAINS=true
AKAY_NO_SHOW_OVERLAP_MINUTES=60
AKAY_TOKEN_PRUNE_TIME=02:15
AKAY_TOKEN_PRUNE_RETENTION_HOURS=24
AKAY_TOKEN_PRUNE_OVERLAP_MINUTES=120
AKAY_HEALTH_RATE_LIMIT_PER_MINUTE=30
AKAY_MAX_TOKEN_EXPIRATION_MINUTES=43200
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=60
AKAY_AUTH_TOKEN_EXPIRATION_MINUTES=480

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=30

# Production logging:
# LOG_CHANNEL=daily
# LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=your-supabase-db-host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=your-supabase-db-user
DB_PASSWORD=your-supabase-db-password
DB_SSLMODE=require

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=
AKAY_SERVER_CACHE_ENABLED=true
AKAY_CACHE_MEDICINE_AVAILABILITY_SECONDS=20
AKAY_CACHE_REPORT_AGGREGATE_SECONDS=120
AKAY_HEALTH_RECORD_DRAFT_EXPIRY_DAYS=30
AKAY_HEALTH_RECORD_DRAFT_RETENTION_DAYS=7
AKAY_HEALTH_RECORD_DRAFT_MAX_ACTIVE=20
AKAY_HEALTH_RECORD_DRAFT_MAX_BYTES=262144
AKAY_HEALTH_RECORD_DRAFT_LIST_PER_PAGE=15
AKAY_HEALTH_RECORD_DRAFT_WRITE_RATE_LIMIT=30
AKAY_DRAFT_PRUNE_TIME=02:45
AKAY_DRAFT_PRUNE_OVERLAP_MINUTES=120

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-address@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-address@gmail.com
MAIL_FROM_NAME="AKAY"

# For local-only development without sending email, you may temporarily use:
# MAIL_MAILER=log

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
